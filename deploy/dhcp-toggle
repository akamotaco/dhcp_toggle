#!/bin/bash
# dhcp-toggle — DHCP 서버 모드 토글 스크립트
# 사용법: dhcp-toggle {a|b|off|status}

set -euo pipefail

CONF_DIR="/etc/dnsmasq.d"
ACTIVE_CONF="$CONF_DIR/dhcp-active.conf"
STATE_FILE="/var/lib/dhcp-toggle/mode"
LOG_FILE="/var/log/dhcp-toggle.log"
LAN_IP="192.168.10.1"
LAN_MASK="24"

# 색상
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

write_log() {
    local level="$1"; shift
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$ts] [$level] $*" >> "$LOG_FILE" 2>/dev/null || true
}

log_info() {
    echo -e "${GREEN}[INFO]${NC} $*"
    write_log "INFO" "$*"
}
log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
    write_log "WARN" "$*"
}
log_error() {
    echo -e "${RED}[ERROR]${NC} $*"
    write_log "ERROR" "$*"
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "이 스크립트는 root 권한이 필요합니다."
        exit 1
    fi
}

get_current_mode() {
    if [[ -f "$STATE_FILE" ]]; then
        cat "$STATE_FILE"
    else
        echo "off"
    fi
}

save_mode() {
    mkdir -p "$(dirname "$STATE_FILE")"
    echo "$1" > "$STATE_FILE"
}

cleanup() {
    local current
    current=$(get_current_mode)
    log_info "이전 모드($current) 정리 중..."

    # dnsmasq 정지
    systemctl stop dnsmasq 2>/dev/null || true

    # 활성 설정 제거
    rm -f "$ACTIVE_CONF"

    # iptables NAT 규칙 제거
    iptables -t nat -F POSTROUTING 2>/dev/null || true
    iptables -F FORWARD 2>/dev/null || true

    # 브릿지 제거 (모드 B 정리)
    if ip link show br0 &>/dev/null; then
        ip link set eth0 nomaster 2>/dev/null || true
        ip link set eth1 nomaster 2>/dev/null || true
        ip link set br0 down 2>/dev/null || true
        ip link delete br0 2>/dev/null || true
        log_info "br0 브릿지 제거 완료"
    fi

    # 인터페이스 IP 제거
    ip addr flush dev eth0 2>/dev/null || true
    ip addr flush dev eth1 2>/dev/null || true

    # IP 포워딩 비활성
    sysctl -q net.ipv4.ip_forward=0

    save_mode "off"
}

mode_a() {
    log_info "모드 A 활성화: eth0=WAN, eth1=LAN"

    # eth0: WAN (DHCP client)
    ip link set eth0 up
    dhclient -nw eth0 2>/dev/null || log_warn "eth0 DHCP 클라이언트 시작 실패 (케이블 확인)"

    # eth1: LAN (고정 IP)
    ip link set eth1 up
    ip addr add "${LAN_IP}/${LAN_MASK}" dev eth1 2>/dev/null || true

    # dnsmasq 설정 활성화
    cp "${CONF_DIR}/../dhcp-mode-a.conf.tpl" "$ACTIVE_CONF" 2>/dev/null || \
        cp /usr/local/share/dhcp-toggle/dhcp-mode-a.conf "$ACTIVE_CONF"
    systemctl restart dnsmasq

    # IP 포워딩
    sysctl -q net.ipv4.ip_forward=1

    # NAT
    iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
    iptables -A FORWARD -i eth1 -o eth0 -j ACCEPT
    iptables -A FORWARD -i eth0 -o eth1 -m state --state RELATED,ESTABLISHED -j ACCEPT

    save_mode "a"
    log_info "모드 A 활성화 완료"
}

mode_b() {
    log_info "모드 B 활성화: wlan0=WAN, br0(eth0+eth1)=LAN"

    # br0 브릿지 생성
    ip link add name br0 type bridge
    ip link set eth0 up
    ip link set eth1 up
    ip link set eth0 master br0
    ip link set eth1 master br0
    ip link set br0 up
    ip addr add "${LAN_IP}/${LAN_MASK}" dev br0

    log_info "br0 브릿지 생성 완료 (eth0 + eth1)"

    # dnsmasq 설정 활성화
    cp /usr/local/share/dhcp-toggle/dhcp-mode-b.conf "$ACTIVE_CONF"
    systemctl restart dnsmasq

    # IP 포워딩
    sysctl -q net.ipv4.ip_forward=1

    # NAT
    iptables -t nat -A POSTROUTING -o wlan0 -j MASQUERADE
    iptables -A FORWARD -i br0 -o wlan0 -j ACCEPT
    iptables -A FORWARD -i wlan0 -o br0 -m state --state RELATED,ESTABLISHED -j ACCEPT

    save_mode "b"
    log_info "모드 B 활성화 완료"
}

show_clients() {
    local mode lan_iface
    mode=$(get_current_mode)

    if [[ "$mode" == "off" ]]; then
        log_warn "DHCP 서버가 비활성 상태입니다."
        return
    fi

    # LAN 인터페이스 결정
    case "$mode" in
        a) lan_iface="eth1" ;;
        b) lan_iface="br0" ;;
    esac

    echo "======================================"
    echo " 접속 클라이언트 목록 (모드: $mode)"
    echo "======================================"

    # 1) DHCP 리스 (dnsmasq가 할당한 IP)
    echo ""
    echo "--- DHCP 할당 클라이언트 ---"
    local lease_file="/var/lib/misc/dnsmasq.leases"
    if [[ -f "$lease_file" ]] && [[ -s "$lease_file" ]]; then
        printf "%-18s %-16s %s\n" "MAC 주소" "IP 주소" "호스트명"
        printf "%-18s %-16s %s\n" "――――――――――――――――" "―――――――――――――" "――――――――"
        while read -r expire mac ip hostname _; do
            local exp_date
            exp_date=$(date -d "@$expire" '+%m/%d %H:%M' 2>/dev/null || echo "$expire")
            printf "%-18s %-16s %-20s (만료: %s)\n" "$mac" "$ip" "$hostname" "$exp_date"
        done < "$lease_file"
    else
        echo "(DHCP 리스 없음)"
    fi

    # 2) ARP 테이블 (실제 통신 중인 호스트)
    echo ""
    echo "--- ARP 테이블 (${lan_iface}) ---"
    printf "%-16s %-18s %s\n" "IP 주소" "MAC 주소" "상태"
    printf "%-16s %-18s %s\n" "―――――――――――――" "――――――――――――――――" "――――"
    ip neigh show dev "$lan_iface" 2>/dev/null | while read -r ip _ mac state; do
        if [[ -n "$mac" && "$mac" != "" ]]; then
            printf "%-16s %-18s %s\n" "$ip" "$mac" "$state"
        fi
    done

    # 3) 요약
    echo ""
    local dhcp_count arp_count
    dhcp_count=$(wc -l < "$lease_file" 2>/dev/null || echo 0)
    arp_count=$(ip neigh show dev "$lan_iface" 2>/dev/null | grep -cv '^$' || echo 0)
    echo "DHCP 할당: ${dhcp_count}대 | ARP 활성: ${arp_count}대"
    echo "======================================"
}

show_status() {
    local mode
    mode=$(get_current_mode)
    echo "=============================="
    echo " DHCP Toggle 상태"
    echo "=============================="
    echo "현재 모드: $mode"
    echo ""

    echo "--- 인터페이스 ---"
    ip -br addr show

    if [[ "$mode" != "off" ]]; then
        echo ""
        echo "--- DHCP 리스 ---"
        cat /var/lib/misc/dnsmasq.leases 2>/dev/null || echo "(리스 없음)"

        echo ""
        echo "--- NAT 규칙 ---"
        iptables -t nat -L POSTROUTING -n 2>/dev/null || echo "(iptables 없음)"

        echo ""
        echo "--- IP 포워딩 ---"
        sysctl net.ipv4.ip_forward

        echo ""
        show_clients
    fi
    echo "=============================="
}

show_log() {
    local lines="${1:-50}"
    if [[ ! -f "$LOG_FILE" ]]; then
        echo "(로그 파일 없음: $LOG_FILE)"
        return
    fi
    echo "=============================="
    echo " dhcp-toggle 로그 (최근 ${lines}줄)"
    echo "=============================="
    tail -n "$lines" "$LOG_FILE"
    echo "=============================="
    echo "전체 로그: $LOG_FILE"
}

show_help() {
    cat <<'HELP'
dhcp-toggle — DHCP 서버 모드 토글 스크립트

사용법:
  sudo dhcp-toggle <command> [options]

명령어:
  a           모드 A 활성화 — 유선 WAN
              eth0=WAN (DHCP client), eth1=LAN (192.168.10.1/24)
              [인터넷] → eth0 → NAT → eth1 → 클라이언트

  b           모드 B 활성화 — Wi-Fi WAN
              wlan0=WAN, br0(eth0+eth1)=LAN (192.168.10.1/24)
              [인터넷] → wlan0 → NAT → br0 [eth0+eth1] → 클라이언트

  off         모든 DHCP/NAT 해제, 데스크톱 모드로 복귀

  status      현재 모드, 인터페이스, NAT 규칙, 클라이언트 정보 출력

  clients     접속 중인 클라이언트 목록
              - DHCP 리스 (할당된 IP/MAC/호스트명)
              - ARP 테이블 (실제 통신 중인 호스트)

  log [N]     최근 로그 출력 (기본 50줄)
              로그 파일: /var/log/dhcp-toggle.log

  help        이 도움말 출력

예제:
  sudo dhcp-toggle a          # 유선 라우터 모드 시작
  sudo dhcp-toggle b          # Wi-Fi 라우터 모드 시작
  sudo dhcp-toggle off        # 라우터 모드 해제
  dhcp-toggle status          # 현재 상태 확인
  dhcp-toggle clients         # 접속 장치 확인
  dhcp-toggle log             # 최근 로그 50줄
  dhcp-toggle log 100         # 최근 로그 100줄

네트워크 구성:
  LAN IP:       192.168.10.1/24
  DHCP 범위:    192.168.10.100 ~ 192.168.10.200
  DNS:          8.8.8.8, 8.8.4.4
  리스 시간:    12시간

파일 위치:
  스크립트:     /usr/local/bin/dhcp-toggle
  설정 파일:    /usr/local/share/dhcp-toggle/
  활성 설정:    /etc/dnsmasq.d/dhcp-active.conf
  상태 파일:    /var/lib/dhcp-toggle/mode
  로그 파일:    /var/log/dhcp-toggle.log
  systemd:      /etc/systemd/system/dhcp-toggle.service
HELP
}

# --- Main ---
case "${1:-}" in
    a)
        require_root
        cleanup
        mode_a
        ;;
    b)
        require_root
        cleanup
        mode_b
        ;;
    off)
        require_root
        cleanup
        log_info "DHCP 서버 비활성화 완료 (데스크톱 모드)"
        ;;
    status)
        show_status
        ;;
    clients)
        show_clients
        ;;
    log)
        show_log "${2:-50}"
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        echo "사용법: dhcp-toggle {a|b|off|status|clients|log|help}"
        echo ""
        echo "  a       — 모드 A: eth0=WAN, eth1=LAN (유선)"
        echo "  b       — 모드 B: wlan0=WAN, eth0+eth1=LAN (Wi-Fi)"
        echo "  off     — DHCP 서버 해제 (데스크톱 모드)"
        echo "  status  — 현재 상태 확인"
        echo "  clients — 접속 클라이언트 목록"
        echo "  log [N] — 최근 로그 출력 (기본 50줄)"
        echo "  help    — 상세 도움말"
        exit 1
        ;;
esac
